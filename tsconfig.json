{
	"compilerOptions": {
		"target": "ES2018",
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "dist",
		"sourceMap": false,
		"allowJs": false,
		"resolveJsonModule": true,
		"noUnusedLocals": true,
		"strict": true,
		"types": ["node"],
		"declaration": true
	},
	"include": ["src/*"]
}
